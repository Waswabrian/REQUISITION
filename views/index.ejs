<% 
  // 1. Filter the data based on user permissions
  let visibleRequisitions = [];

  if (user.username === 'finance' || user.username === 'brian') {
      // Full access: see everything
      visibleRequisitions = requisitions;
  } else if (user.username === 'hod') {
      // Departmental access: see only their department
      visibleRequisitions = requisitions.filter(r => r.department === user.department);
  } else {
      // Staff access: see only their own submissions
      visibleRequisitions = requisitions.filter(r => r.submittedBy === user.username);
  }
%>




    <!-- Requisition progress tracker -->
    <section class="progress-tracker" style="margin-top: 20px; width: 100%;">
        <h3>My Requisition Progress</h3>
        <% if (requisitions && requisitions.length > 0) { %>
            <table id="tracking-table" style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr>
                        <th style="border: 1px solid #ddd; padding: 8px;">ID</th>
                        <th style="border: 1px solid #ddd; padding: 8px;">Staff-Name</th>
                        <th style="border: 1px solid #ddd; padding: 8px;">Department</th>
                        <th style="border: 1px solid #ddd; padding: 8px;">Request Date</th>
                        <th style="border: 1px solid #ddd; padding: 8px;">Status</th>
                        <th style="border: 1px solid #ddd; padding: 8px;">Action</th>
                    </tr>
                </thead>
                <tbody>
                <% requisitions.forEach(req => { %>
                <tr>
                    <td style="border: 1px solid #ddd; padding: 8px;"><%= req.id %></td>
                    <td style="border: 1px solid #ddd; padding: 8px;"><%= req.staffName %></td>
                    <td style="border: 1px solid #ddd; padding: 8px;"><%= req.department %></td>
                    <td style="border: 1px solid #ddd; padding: 8px;"><%= new Date(req.requestDate).toLocaleDateString() %></td>
                    <td style="border: 1px solid #ddd; padding: 8px;"><strong><%= req.status %></strong></td>
                    <td style="border: 1px solid #ddd; padding: 8px;"><a href="/hod/approval/<%= req.id %>">View</a></td>
                </tr>
                <% }) %>
                </tbody>
            </table>
        <% } else { %>
            <p>No previous requisitions found yet. Submit one and it will appear here.</p>
        <% } %>
    </section>

        <script src="/scripts/table-logic.js"></script>
    </body>

</html>