<!DOCTYPE html>
<html>
    <head>
        <title>ICT Requisition form</title> 
        <link rel="stylesheet" href="/styles/index.css">
    </head>
    <body>
        <div class="top">
            <img src="/Images/octagon-logo.png" id="logo">
            <h2 id="headline"><u>PURCHASE REQUISITION FORM</u></h2>
        </div>

        <div class="tables">
            <section id="date">
            <form>
                <table id="table1">
                    <tr>
                        <td>DATE</td>
                        <td id="datae"> <input type="date" name="requestdate" id="date" style="border:none;"></td>
                    </tr>
                     <tr>
                        <td id="datae"  > DEPARTMENT</td>
                        <td><select><option>Department</option>
                        <option value="Admin">Admin</option>
                        <option value="HR">HR</option>
                        <option value="finance">Finance</option>
                        <option value="support">Customer Experience</option>
                        <option value="IT">IT</option>
                        <option value="BD">BD</option>
                        </select></td>
                        
                    </tr>   
                </table>
            </form>
            </section>
        </div>     

        <div class="tables2">
            <section id="costs">
            <form>    
                <table id="table2">
                    <thead>
                    <tr style="font-weight: bold;">
                        <td>S/N</td>
                        <td>Budget Line </td>
                        <td>Cost centre </td>
                        <td>Item Description</td>
                        <td>Quantity </td>
                        <td>Unit </td>
                        <td>Total</td>
                    </tr>
                    </thead>
                    <tbody id="itembody">
                     <tr>
                        <td > <input type="number" placeholder="" style="border:none;"></td>
                        <td> <input type="text" placeholder="1" style="border:none;"></td>
                        <td> <input type="text" placeholder="1" style="border:none;"></td>
                        <td> <textarea style="border:none;"></textarea></td>
                        <td> <input type="number" placeholder="1" style="border:none;"></td>    
                        <td> <input type="number" placeholder="1" style="border:none;"></td>
                        <td> <input type="text" placeholder="1" style="border:none;"></td>
                        <td><button type="button" id="add-row" onclick="addRow()">+</button></td>
                    </tr>
                    </tbody>
                    <!-- <tr>
                        <td><button type="button" onclick="addRow()">Add Items</button></td>
                    </tr>
                     -->
                    
                    
                </table>
             
            </form>
            </section>
        </div>

