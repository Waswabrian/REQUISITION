     <div class="approval-container">
    <div class="approval-row">
        <div class="field-group">
            <span class="label">Prepared by:</span>
            <div class="line">{username}</div>
        </div>
        <div class="field-group date-group">
            <span class="label">Date:</span>
            <div class="line small-line">{date}</div>
        </div>
    </div>

    <div class="approval-row">
        <div class="field-group">
            <span class="label">Checked by: HOD/ Supervisor:</span>
            <!-- <div class="line"><button><input type="text" style="border:none;"></button></div> -->
            <div><button><input type="text" style="border:none;"></button></div>
        </div>
        <div class="field-group">
            <span class="label">Signature:</span>
            <!-- <div class="line">{upload online signature}\if can draw </div> -->
            <input type="file" name="supportDoc"  id="supportDoc" class="line">
        </div>
    </div>

    <div class="approval-row">
        <div class="field-group">
            <span class="label">Authorized by: Finance:</span>
            <!-- <div class="line"></div> -->
            <div><button style="margin-left:50px;"><input type="text" style="border:none;"></button></div>
        </div>
        <div class="field-group">
            <span class="label">Signature:</span>
            <!-- <div class="line"></div> -->
            <input type="file" name="supportDoc"  id="supportDoc" class="line">
        </div>
    </div>

    <div class="approval-row">
        <div class="field-group">
            <span class="label">Approved by: Director:</span>
            <!-- <div class="line"></div> -->
              <div><button style="margin-left:55px;"><input type="text" style="border:none;"></button></div>    
        </div>
        <div class="field-group">
            <span class="label">Signature:</span>
            <!-- <div class="line"></div> -->
            <input type="file" name="supportDoc"  id="supportDoc" class="line"></div>
        </div>
    </div>
</div>
<div class="submit-btn">
    <button id ="submit" type="submit" action="submit" onclick="submit()">Request</button>
</div>
