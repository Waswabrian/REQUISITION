<!DOCTYPE html>
<html>
<head>
    <title>HOD Approval - Requisition <%= requisition.id %></title>
    <link rel="stylesheet" href="/styles/approve_form.css">
    <script src="https://cdn.jsdelivr.net/npm/signature_pad@4.0.0/dist/signature_pad.umd.min.js"></script>
</head>
<body>
    <div class="top">
        <img src="/Images/octagon-logo.png" id="logo">
        <h2>HOD APPROVAL INTERFACE</h2>
    </div>

    <%- include('partials/nav') %>
    <!-- <nav class="main-nav">
        <a href="/">New Requisition</a>
        <a href="/hod/dashboard">HOD Dashboard</a>
        <a href="/finance/dashboard">Finance Dashboard</a>
        <a href="/director/dashboard">Director Dashboard</a>
    </nav> -->

    <div class="summary-box">
        <p><strong>Requisition ID:</strong> <%= requisition.id %></p>
        <p><strong>Staff:</strong> <%= requisition.staffName || 'Unknown' %></p>
        <p><strong>Department:</strong> <%= requisition.department || 'N/A' %></p>
        <p><strong>Date:</strong> <%= requisition.requestDate || 'N/A' %></p>
        <td class="<%= (req.grandTotal > 100000) ? 'high-value' : '' %>">
                        KES <%= Number(req.grandTotal || 0).toLocaleString(undefined, {
                            minimumFractionDigits: 2, 
                            maximumFractionDigits: 2
                        }) %>
                    </td>
         <p><strong>Grand Total:</strong> KES <%= (requisition.grandTotal || (requisition.items || []).reduce((acc, i) => acc + Number(i.total || 0), 0)).toFixed(2) %></p> 
        <p><a href="/hod/dashboard" style="color: #fff; background: #0071bc; padding: 7px 12px; text-decoration: none; border-radius: 4px;">Back to Dashboard</a></p>
    </div>

   <table>
        <thead>
            <tr style="font-weight: bold; background: #f5f5f5;">
                <th>Item Description</th>
                <th>Quantity</th>
                <th>Unit Price (KES)</th>
                <th>Total (KES)</th>
             </tr>
        </thead>
        <tbody>
            <% 
            let itemsArray = [];
            if (requisition.items) {
                if (Array.isArray(requisition.items)) {
                    itemsArray = requisition.items;
                } else if (typeof requisition.items === 'string') {
                    try {
                        itemsArray = JSON.parse(requisition.items);
                    } catch(e) {
                        console.error('Error parsing items:', e);
                        itemsArray = [];
                    }
                }
            }
            
            if (itemsArray.length > 0) {
                itemsArray.forEach(item => { 
                    const itemTotal = Number(item.total) || (Number(item.qty) * Number(item.unitPrice)) || 0;
            %>
            <tr>
                <td><%= item.items || 'N/A' %></td>
                <td><%= item.qty || 0 %></td>
                <td>KES <%= (Number(item.unitPrice) || 0).toFixed(2) %></td>
               <td style="padding: 12px;" class="<%= req.grandTotal > 100000 ? 'high-value' : '' %>">
                    KES <%= Number(req.grandTotal).toLocaleString(undefined, {minimumFractionDigits: 2}) %>
                </td>
            </tr>
            <% }); } else { %>
            <tr>
                <td colspan="4" style="text-align: center;">No items found</td>
            </tr>
            <% } %>
        </tbody>
    </table>
    <form id="approvalForm" action="/hod/submit-approval/<%= requisition.id %>" method="POST">
        <div class="approval-container">
            <h3>HOD/Supervisor Action</h3>
            <canvas id="signature-pad" style="border: 1px solid #000; width: 400px; height: 200px;"></canvas>
            <input type="hidden" name="signature" id="signature-db">
            
            <div style="margin-top: 20px;">
                <button type="submit" name="action" value="approve" style="background: green; color: white;">Approve to Finance</button>
                <button type="submit" name="action" value="reject" style="background: red; color: white;">Reject Request</button>
            </div>
        </div>
    </form>
<script>
    const canvas = document.getElementById('signature-pad');
    const signaturePad = new SignaturePad(canvas, {
        backgroundColor: 'rgb(255, 255, 255)' // Ensures a clean white background
    });

    // Adjust canvas resolution for high-DPI screens
    function resizeCanvas() {
        const ratio = Math.max(window.devicePixelRatio || 1, 1);
        canvas.width = canvas.offsetWidth * ratio;
        canvas.height = canvas.offsetHeight * ratio;
        canvas.getContext("2d").scale(ratio, ratio);
        signaturePad.clear(); // otherwise scale() clears the canvas
    }

    window.onresize = resizeCanvas;
    resizeCanvas();

    const form = document.getElementById('approvalForm');
    form.onsubmit = function(e) {
        if (signaturePad.isEmpty()) {
            alert("Please provide a signature before submitting.");
            return false;
        }
        
        // Convert the signature to a Base64 string
        const dataURL = signaturePad.toDataURL('image/png');
        document.getElementById('signature-db').value = dataURL;
        return true;
    };

    // Optional: Add a button in your HTML with id="clear-btn" to use this:
    // document.getElementById('clear-btn').addEventListener('click', () => signaturePad.clear());
</script>>
</body>
</html>