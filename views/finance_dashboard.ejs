<!DOCTYPE html>
<html>
<head>
    <title>Finance Dashboard</title>
    <link rel="stylesheet" href="/styles/finance_dashboard.css">
</head>
<body>
    <div class="top">
            <img src="/Images/octagon-logo.png" id="logo">
            <h2 id="headline"><u>FINANCE DASHBOARD</u></h2>
    </div>
    <nav class="main-nav">
        <a href="/">New Requisition</a>
        <a href="/hod/dashboard">HOD Dashboard</a>
        <a href="/finance/dashboard">Finance Dashboard</a>
        <a href="/director/dashboard">Director Dashboard</a>
    </nav>

    <% if (!requests || requests.length === 0) { %>
        <p>No requisitions waiting for finance authorization.</p>
    <% } else { %>
        <table id="table2">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Staff</th>
                    <th>Department</th>
                    <th>Date</th>
                    <th>Total</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                <% requests.forEach((req) => { %>
                <tr>
                    <td><%= req.id %></td>
                    <td><%= req.staffName %></td>
                    <td><%= req.department %></td>
                    <td><%= req.requestDate %></td>
                    <td><%= req.items.reduce((sum, item) => sum + Number(item.total || 0), 0).toFixed(2) %></td>
                    <td><a href="/finance/approval/<%= req.id %>">Authorize</a></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    <% } %>
</body>
</html>